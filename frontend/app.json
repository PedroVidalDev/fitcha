{
    "expo": {
        "name": "Fitcha",
        "slug": "fitcha",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./src/assets/images/icon.png",
        "scheme": "fitcha",
        "userInterfaceStyle": "automatic",
        "newArchEnabled": true,
        "ios": {
            "supportsTablet": true
        },
        "android": {
            "package": "com.pedrovidaldev.fitcha",
            "edgeToEdgeEnabled": true,
            "predictiveBackGestureEnabled": false
        },
        "web": {
            "output": "static"
        },
        "plugins": [
            "expo-notifications",
            {
                "icon": "./src/assets/images/icon.png",
                "color": "#F4A261",
                "defaultChannel": "treino"
            }
        ],
        "experiments": {
            "typedRoutes": true,
            "reactCompiler": true
        },
        "extra": {
            "router": {},
            "eas": {
                "projectId": "f19f2656-d5ab-4268-a6ac-f11c2f7e44b2"
            }
        }
    }
}
